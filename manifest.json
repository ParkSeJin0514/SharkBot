{
  "display_information": {
    "name": "Sharkton",
    "description": "스마일샤크 고객 문의 봇 - Slack에서 바로 Zendesk 티켓 발행",
    "background_color": "#0a2540"
  },
  "features": {
    "bot_user": {
      "display_name": "Sharkton",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/sharkton",
        "description": "스마일샤크에 문의 티켓을 보냅니다",
        "usage_hint": "문의 폼 열기",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "commands",
        "chat:write",
        "chat:write.public",
        "users:read",
        "users:read.email",
        "im:write"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
